# ─── Supabase ──────────────────────────────────────────────────────────────
# Leave blank to auto-read these from ../main_website/.env.local
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ─── Email sending (Resend HTTPS API) ─────────────────────────────────────
# 1. Sign up at https://resend.com (free: 100/day, 3000/mo).
# 2. Domains → add yogher.in → add the DNS records they show you.
# 3. API Keys → create one → paste below as RESEND_API_KEY.
# 4. EMAIL_FROM must use the domain you verified — e.g. hello@yogher.in.
#    (For first-time testing, you can use onboarding@resend.dev.)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=hello@yogher.in
EMAIL_FROM_NAME=YogHer

# ─── Behaviour ─────────────────────────────────────────────────────────────
# DRY_RUN=true prints emails to the console instead of sending them. Keep it
# true until you've reviewed the output, then set to false to actually send.
DRY_RUN=true

# How long a customer must be idle at a stage before we email them (minutes).
# This is the "wait" — if they're still moving step→step we leave them alone.
WAIT_MINUTES=60

# Don't send nudges for journeys older than this (days).
MAX_AGE_DAYS=14

# ─── Follow-up sequence ────────────────────────────────────────────────────
# Days after first contact (lead created) to send the follow-ups. 0 = immediate
# (sent on the very next cron run after the lead is created).
FOLLOWUP_OFFSETS_DAYS=0,1,7,15

# Daily send cap — follow-ups AND manual bulk blasts share this budget.
# Keep it safely under Gmail's limit (free ≈ 500/day, Workspace ≈ 2000/day).
MAX_PER_DAY=450

# ─── Admin web app (separate dashboard) ────────────────────────────────────
# Basic-auth login for the admin app (python main.py web). Set a real password
# before exposing it on a network — the app refuses to start without ADMIN_PASS.
ADMIN_USER=admin
ADMIN_PASS=

# Shared secret for the external-cron trigger: /cron/followups?key=THIS.
# Use a long random string. The endpoint is off until this is set.
CRON_SECRET=

# ─── Scheduler ───────────────────────────────────────────────────────────────
# Two ways to run the follow-ups automatically — use ONE:
#  (a) External cron (recommended on a free/stateless host): leave the built-in
#      scheduler off and have cron-job.org / GitHub Actions hit /cron/followups.
#  (b) Built-in scheduler: only reliable on an always-on host.
SCHEDULER_ENABLED=false
# For (b) only — hours of day to run (24h, comma-separated), e.g. "6,11,16,21".
FOLLOWUP_HOURS=10
# Minutes east of UTC for the hours above. India (IST) = 330.
SCHEDULER_OFFSET_MINUTES=330

# Links used inside the emails
SITE_URL=https://yogher.in
WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/your-invite
SUPPORT_WHATSAPP=+919457592078
